# Database
POSTGRES_PASSWORD=change_me_in_production

# Auth
NEXTAUTH_SECRET=generate_a_long_random_secret_here
NEXTAUTH_URL=http://localhost:3456

# Admin seed (created on first deploy if not exists)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_admin_password

# Spotify (optional for metadata; required for playback)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# YouTube (optional — oEmbed works without a key)
YOUTUBE_API_KEY=

# Ports (used by deploy.sh)
HOST_PORT=3456
WS_HOST_PORT=3457

# Docker Compose project name (must match deploy --project-name for Forge status)
COMPOSE_PROJECT_NAME=playlists
